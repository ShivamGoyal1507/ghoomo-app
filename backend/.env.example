# Supabase Postgres connection string
# Format: postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
# URL-encode special password characters, for example @ as %40.
SUPABASE_DB_URL=postgresql://postgres.<project-ref>:<url-encoded-password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# Optional: one-time import from backend/data/store.json into Supabase when DB is empty.
# Set to true for the first boot only, then switch back to false.
SUPABASE_BOOTSTRAP_FROM_JSON=false

# Optional tuning
DB_POOL_MAX=10
HOST=0.0.0.0
PORT=4000
